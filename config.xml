<?xml version='1.0' encoding='utf-8'?>
<widget id="com.terrible.khata" version="1.0.0" xmlns="http://www.w3.org/ns/widgets" xmlns:cdv="http://cordova.apache.org/ns/1.0">
    <name>Khata App</name>
    <description>Tuhada Apna Khata Ledger App</description>
    <author email="gurmeet@example.com">Gurmeet</author>
    
    <!-- Wapas asli app (index.html) te le aaye -->
    <content src="index.html" />
    <access origin="*" />
    
    <!-- 🟢 NATIVE THEME PLUGIN AITHE LA DITTA HAI -->
    <plugin name="cordova-plugin-theme-detection" spec="^1.3.0" />
    
    <!-- Fallback icon (Purane phonan layi pakka zaroori hai) -->
    <icon src="www/assets/res/icon.png" />
    
    <allow-intent href="http://*/*" />
    <allow-intent href="https://*/*" />
    <allow-intent href="tel:*" />
    <allow-intent href="sms:*" />
    <allow-intent href="mailto:*" />
    <allow-intent href="geo:*" />
    
    <preference name="android-hardwareAccelerated" value="true" /> 
    <preference name="DisallowOverscroll" value="true" /> 
    <preference name="ScrollEnabled" value="false" />
    <preference name="KeepRunning" value="true" /> 
    <preference name="GradlePluginKotlinEnabled" value="true" />
    
    <platform name="android">
        <allow-intent href="market:*" />
        
        <!-- 🟢 100% PUKKA ILAEJ: Explicit Densities -->
        <icon density="mdpi" background="www/assets/res/icon-bg.png" foreground="www/assets/res/icon-fg.png" />
        <icon density="hdpi" background="www/assets/res/icon-bg.png" foreground="www/assets/res/icon-fg.png" />
        <icon density="xhdpi" background="www/assets/res/icon-bg.png" foreground="www/assets/res/icon-fg.png" />
        <icon density="xxhdpi" background="www/assets/res/icon-bg.png" foreground="www/assets/res/icon-fg.png" />
        <icon density="xxxhdpi" background="www/assets/res/icon-bg.png" foreground="www/assets/res/icon-fg.png" />
        
        <preference name="AndroidWindowSplashScreenAnimatedIcon" value="www/assets/res/splash.png" />
        <preference name="AndroidWindowSplashScreenBackground" value="#f4f6f8" />

        <resource-file src="www/assets/res/values/colors.xml" target="app/src/main/res/values/colors.xml" />
        <resource-file src="www/assets/res/values-night/colors.xml" target="app/src/main/res/values-night/colors.xml" />
        
        <preference name="SplashScreenDelay" value="500" />
        <preference name="FadeSplashScreen" value="true" />
        <preference name="FadeSplashScreenDuration" value="300" />
        
        <preference name="AndroidPersistentFileLocation" value="Internal" />
    </platform>
</widget>
